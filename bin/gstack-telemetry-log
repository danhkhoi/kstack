#!/usr/bin/env bash
# gstack-telemetry-log — DISABLED in kstack fork (no telemetry)
# Cleans up any stale .pending-* markers and exits silently.
set -uo pipefail

STATE_DIR="${KSTACK_STATE_DIR:-${GSTACK_STATE_DIR:-$HOME/.kstack}}"
PENDING_DIR="$STATE_DIR/analytics"

SESSION_ID=""
while [ $# -gt 0 ]; do
  case "$1" in
    --session-id) SESSION_ID="$2"; shift 2 ;;
    *) shift ;;
  esac
done

[ -n "$SESSION_ID" ] && rm -f "$PENDING_DIR/.pending-$SESSION_ID" 2>/dev/null || true
exit 0
